---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import HomeSectionPreview from '../components/HomeSectionPreview.astro';
import WorkCard from '../components/WorkCard.astro';

import work from '../content/work.json';
import allProjects from '../content/all-projects.json';
import allPapers from '../content/all-papers.json';

const topWork = work.slice(0, 2);
// Show a mix: 2 applications + 1 hack
const topProjects = [
  ...allProjects.filter(p => p.category === 'application').slice(0, 2),
  ...allProjects.filter(p => p.category === 'hack').slice(0, 1),
];
// Show 3 recent papers/blogs
const topPapers = allPapers.slice(0, 3);
---
<BaseLayout title="Sankalp Gulati — AI Researcher & Data Scientist">
  <Hero />

  <HomeSectionPreview title="Work" href="/work">
    {topWork.map(entry => (
      <WorkCard
        company={entry.company}
        role={entry.role}
        period={entry.period}
        description={entry.description}
        url={entry.url || undefined}
      />
    ))}
  </HomeSectionPreview>

  <HomeSectionPreview title="Projects" href="/projects" alt>
    <div class="preview-grid">
      {topProjects.map(p => (
        <div class="preview-card">
          <div class="preview-card__top">
            <span class="preview-card__title">{p.title}</span>
            {'award' in p && p.award && <span class="preview-card__award">🏆</span>}
          </div>
          <span class="preview-card__sub">{p.subtitle}</span>
          <div class="preview-card__meta">
            <span class:list={['meta-topic', `topic-${p.topic.toLowerCase().replace(/\s+/g, '-')}`]}>{p.topic}</span>
            <span class="meta-company">{p.company}</span>
          </div>
        </div>
      ))}
    </div>
  </HomeSectionPreview>

  <HomeSectionPreview title="Blogs & Papers" href="/papers">
    <div class="papers-preview">
      {topPapers.map(p => (
        <div class="paper-row">
          <div class="paper-row__main">
            <span class="paper-row__title">{p.title}</span>
            <span class="paper-row__meta">{p.company} · {p.year}</span>
          </div>
          <div class="paper-row__badges">
            <span class:list={['meta-topic', `topic-${p.topic.toLowerCase().replace(/\s+/g, '-')}`]}>{p.topic}</span>
            <span class="meta-type">{p.type}</span>
          </div>
        </div>
      ))}
    </div>
  </HomeSectionPreview>
</BaseLayout>

<style>
  /* Projects preview */
  .preview-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .preview-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 4px;
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 180px;
  }
  .preview-card__top { display: flex; align-items: center; gap: 6px; }
  .preview-card__title { font-size: 13px; font-weight: 700; color: var(--navy); }
  .preview-card__award { font-size: 12px; }
  .preview-card__sub { font-size: 11px; color: #6b7280; }
  .preview-card__meta { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 4px; }

  /* Papers preview */
  .papers-preview { display: flex; flex-direction: column; gap: 0; }
  .paper-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid #f3f4f6;
  }
  .paper-row:last-child { border-bottom: none; }
  .paper-row__main { display: flex; flex-direction: column; gap: 3px; flex: 1; }
  .paper-row__title { font-size: 13px; font-weight: 600; color: var(--navy); line-height: 1.4; }
  .paper-row__meta { font-size: 11px; color: #9ca3af; }
  .paper-row__badges { display: flex; flex-direction: column; gap: 4px; align-items: flex-end; flex-shrink: 0; }

  /* Shared meta badges */
  .meta-topic {
    font-size: 10px; font-weight: 600;
    padding: 2px 7px; border-radius: 10px;
  }
  .topic-healthcare-ai { color: #2563eb; background: #eff6ff; }
  .topic-music-ai { color: #7c3aed; background: #f5f3ff; }
  .topic-alternate-data { color: #0891b2; background: #ecfeff; }
  .meta-company {
    font-size: 10px; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase;
    color: #6b7280; background: #f3f4f6; padding: 2px 7px; border-radius: 10px;
  }
  .meta-type {
    font-size: 10px; color: #9ca3af;
    padding: 2px 7px; border-radius: 10px;
    border: 1px solid #e5e7eb; text-transform: capitalize;
  }
</style>
