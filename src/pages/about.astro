---
import BaseLayout from '../layouts/BaseLayout.astro';

const reviewerRoles = [
  { venue: 'International Society for Music Information Retrieval (ISMIR)', years: '2013–2018', note: '5 years' },
  { venue: 'IEEE/ACM Transactions on Audio, Speech, and Language Processing', years: '2016, 2017', note: '' },
  { venue: 'IEEE Transactions on Multimedia', years: '2017', note: '' },
  { venue: 'Journal of New Music Research (JNMR)', years: '2016', note: '' },
  { venue: 'EURASIP Journal on Audio, Speech, and Music Processing', years: '2018', note: '' },
  { venue: 'IEEE Journal of Selected Topics in Signal Processing', years: '2018', note: '' },
  { venue: 'Journal of Intelligent Information Systems (JIIS)', years: '2016', note: '' },
  { venue: 'Speech Music and Mind (SMM)', years: '2018', note: '' },
  { venue: 'National Conference on Communications (NCC)', years: '2015', note: '' },
];
---

<BaseLayout title="About — Sankalp Gulati">
  <div class="container section">

    <div class="about-hero">
      <img src="/photo.jpg" alt="Sankalp Gulati" class="about-photo" />
      <div class="about-intro">
        <h1 class="about-name">Sankalp Gulati</h1>
        <p class="about-role">Chief Data Scientist · EkaCare</p>
        <div class="about-links">
          <a href="https://www.linkedin.com/in/sankalpgulati/" target="_blank" rel="noopener" class="about-link">LinkedIn</a>
          <a href="https://scholar.google.com/citations?user=rJSKxAMAAAAJ&hl=en" target="_blank" rel="noopener" class="about-link">Google Scholar</a>
          <a href="https://github.com/sankalpg" target="_blank" rel="noopener" class="about-link">GitHub</a>
        </div>
      </div>
    </div>

    <div class="about-body">

      <section class="about-section">
        <h2 class="section-label">About</h2>
        <div class="bio-text">
          <p>
            I'm drawn to problems where the signal is rich, the structure is hidden, and the stakes are real. That thread has run through everything I've done — whether the signal was an audio waveform, a corpus of employee reviews, or a doctor speaking to a patient in Kannada.
          </p>
          <p>
            It started with music. I spent a decade trying to teach computers to understand Indian classical music — not just recognize it, but grasp something of its internal logic. A raga isn't a scale. It's a living melodic grammar, built from ornaments and phrases and emotional intention that unfolds differently every time. Formalizing that computationally, from raw audio, with no cheating — that problem is still one of the most beautiful I've encountered. It taught me that the most interesting AI challenges are the ones where human knowledge is deep, culturally specific, and doesn't arrive pre-labeled.
          </p>
          <p>
            Then came a detour through the world of private capital — using machine learning to read the economy through unconventional lenses. What do Glassdoor reviews tell you about a company's trajectory six months out? Can you map competitive dynamics across thousands of private companies just from how they talk about themselves online? Does electricity consumption, or noise complaints in a city, tell you something about recovery before the official numbers arrive? This chapter was about one thing: finding truth in data that wasn't designed to contain it.
          </p>
          <p>
            Now I'm building AI for Indian healthcare, and the challenge feels bigger than anything I've worked on before. The scale is enormous — over a billion people, most of them accessing care through a system that runs on paper, on memory, on overworked doctors who see fifty patients a day. The diversity is staggering — twenty-two languages, scripts, clinical vocabularies, accents, handwriting styles. General-purpose AI, trained on English internet text, doesn't cut it here. What's needed are models that actually know what they're doing in this specific context, that can be trusted in a clinical setting, and that work at Indian scale.
          </p>
          <p>
            What ties all of this together, I think, is a belief that the most valuable thing AI can do is close the gap between what a domain expert knows and what a person without access to that expert can get. In music, that meant democratizing the feedback of a classical guru. In healthcare, it means getting the equivalent of a well-trained doctor's attention to every patient, in their language, in their context — regardless of where they are.
          </p>
        </div>
      </section>

      <section class="about-section">
        <h2 class="section-label">Education</h2>
        <div class="edu-list">
          <div class="edu-row">
            <div class="edu-main">
              <span class="edu-degree">PhD, Music Technology</span>
              <span class="edu-inst">Music Technology Group, Universitat Pompeu Fabra · Barcelona</span>
            </div>
            <span class="edu-year">2016</span>
          </div>
          <div class="edu-row">
            <div class="edu-main">
              <span class="edu-degree">Master's, Sound and Music Computing</span>
              <span class="edu-inst">Music Technology Group, Universitat Pompeu Fabra · Barcelona</span>
            </div>
            <span class="edu-year">2012</span>
          </div>
          <div class="edu-row">
            <div class="edu-main">
              <span class="edu-degree">B.Tech, Electrical Engineering</span>
              <span class="edu-inst">Indian Institute of Technology (IIT) Kanpur</span>
            </div>
            <span class="edu-year">2008</span>
          </div>
        </div>
      </section>

      <section class="about-section">
        <h2 class="section-label">Peer Review</h2>
        <div class="service-list">
          {reviewerRoles.map(r => (
            <div class="service-row">
              <span class="service-venue">{r.venue}</span>
              <span class="service-year">{r.years}{r.note ? ` · ${r.note}` : ''}</span>
            </div>
          ))}
        </div>
      </section>

      <section class="about-section">
        <h2 class="section-label">Teaching</h2>
        <div class="teaching-list">
          <div class="teaching-row">
            <div class="teaching-main">
              <span class="teaching-course">Audio Signal Processing for Music Applications (ASPMA)</span>
              <span class="teaching-where">Coursera MOOC · Music Technology Group, UPF · 2014–2015</span>
              <span class="teaching-desc">Designed and implemented programming assignments and automated assessment tools for a global online course.</span>
            </div>
          </div>
          <div class="teaching-row">
            <div class="teaching-main">
              <span class="teaching-course">Processament de So i Música</span>
              <span class="teaching-where">Universitat Pompeu Fabra, Barcelona · 2013–2015</span>
              <span class="teaching-desc">Teaching assistant — conducted seminars and lab sessions, created programming assignments with automatic graders.</span>
            </div>
          </div>
        </div>
      </section>

      <section class="about-section" id="contact">
        <h2 class="section-label">Contact</h2>
        <div class="contact-links">
          <a href="https://www.linkedin.com/in/sankalpgulati/" target="_blank" rel="noopener" class="contact-btn">LinkedIn</a>
          <a href="https://scholar.google.com/citations?user=rJSKxAMAAAAJ&hl=en" target="_blank" rel="noopener" class="contact-btn">Google Scholar</a>
          <a href="https://github.com/sankalpg" target="_blank" rel="noopener" class="contact-btn">GitHub</a>
          <a href="https://soundcloud.com/sankalpgulati" target="_blank" rel="noopener" class="contact-btn">SoundCloud</a>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .about-hero {
    display: flex;
    align-items: center;
    gap: 28px;
    padding: 36px 0 40px;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 40px;
  }
  .about-photo {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .about-name { font-size: 26px; font-weight: 900; color: var(--navy); margin: 0 0 4px; }
  .about-role { font-size: 12px; letter-spacing: 2px; text-transform: uppercase; opacity: 0.5; margin: 0 0 14px; }
  .about-links { display: flex; flex-wrap: wrap; gap: 8px; }
  .about-link {
    font-size: 12px;
    color: var(--navy);
    background: #f3f4f6;
    padding: 5px 12px;
    border-radius: 2px;
    border: 1px solid #e5e7eb;
    transition: background 0.15s;
  }
  .about-link:hover { background: #e5e7eb; text-decoration: none; }

  .about-body { display: flex; flex-direction: column; gap: 48px; }
  .about-section {}
  .section-label {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #9ca3af;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid #f3f4f6;
  }

  /* Bio */
  .bio-text { display: flex; flex-direction: column; gap: 14px; }
  .bio-text p { font-size: 14px; line-height: 1.75; color: #374151; margin: 0; }
  .bio-text strong { color: var(--navy); font-weight: 700; }

  /* Education */
  .edu-list { display: flex; flex-direction: column; }
  .edu-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid #f3f4f6;
  }
  .edu-row:last-child { border-bottom: none; }
  .edu-main { display: flex; flex-direction: column; gap: 3px; }
  .edu-degree { font-size: 14px; font-weight: 600; color: var(--navy); }
  .edu-inst { font-size: 12px; color: #6b7280; }
  .edu-year { font-size: 12px; color: #9ca3af; flex-shrink: 0; }

  /* Service */
  .service-list { display: flex; flex-direction: column; }
  .service-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding: 10px 0;
    border-bottom: 1px solid #f3f4f6;
    flex-wrap: wrap;
  }
  .service-row:last-child { border-bottom: none; }
  .service-venue { font-size: 13px; color: var(--navy); font-weight: 500; }
  .service-year { font-size: 12px; color: #6b7280; flex-shrink: 0; }

  /* Teaching */
  .teaching-list { display: flex; flex-direction: column; gap: 12px; }
  .teaching-row { padding: 14px; background: #f9fafb; border-radius: 4px; border: 1px solid #f3f4f6; }
  .teaching-main { display: flex; flex-direction: column; gap: 3px; }
  .teaching-course { font-size: 14px; font-weight: 700; color: var(--navy); }
  .teaching-where { font-size: 11px; color: #6b7280; }
  .teaching-desc { font-size: 13px; color: #6b7280; line-height: 1.5; margin-top: 5px; }

  /* Contact */
  .contact-links { display: flex; flex-wrap: wrap; gap: 10px; }
  .contact-btn {
    font-size: 13px;
    font-weight: 600;
    color: var(--navy);
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    padding: 8px 18px;
    border-radius: 2px;
    transition: background 0.15s;
  }
  .contact-btn:hover { background: #f3f4f6; text-decoration: none; }

  @media (max-width: 480px) {
    .about-hero { flex-direction: column; align-items: flex-start; }
  }
</style>
